# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Local Claude Code agent config.
.claude/

# Per-spawn Arbiter.MCP client config — written into each acolyte worktree by
# Arbiter.MCP.AgentConfig with a bearer scope token baked in. Never commit it.
.mcp.json

# Agent-generated build artifacts — not part of the canonical repo.
BUILD-SUMMARY-*.md
MORNING-BRIEF.md


# Arbiter run artifacts
.arbiter/

# Compiled Erlang/Elixir beam artifacts — mix test can compile these into the
# worktree root (e.g. Elixir.Arbiter.Worker.Worktree.beam). They are never
# part of the canonical repo and must not trip the commit gate (bd-3gpeoz).
*.beam
